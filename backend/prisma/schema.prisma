// Cabana Lanches — schema Prisma
// DB atual: SQLite. Migração p/ Postgres: trocar provider + DATABASE_URL.
// OBS: SQLite/Prisma não suporta `enum` nativo, então os campos de status são
// String, com os valores válidos garantidos pela camada de aplicação
// (@cabana/shared: enums + zod + OrderStateMachine). Em Postgres pode-se
// promover para enums depois sem alterar a lógica.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== Usuários finais (clientes) =====
model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  password  String
  addresses Address[]
  orders    Order[]
  ratings   Rating[]
  createdAt DateTime  @default(now())
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  lat          Float?
  lng          Float?
  isDefault    Boolean @default(false)
  orders       Order[]

  @@index([userId])
}

// ===== Catálogo =====
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  products  Product[]
  coupons   Coupon[]
}

model Product {
  id           String      @id @default(cuid())
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  ingredients  String?
  prepNotes    String?
  price        Decimal
  imageUrl     String?
  active       Boolean     @default(true)
  promoActive  Boolean     @default(false)
  promoPercent Int?
  // Desconto adicional quando o pagamento é via PIX (aplicado sobre o preço já promocional)
  pixPromoActive  Boolean  @default(false)
  pixPromoPercent Int?
  // Customização: null = sem limite (à vontade)
  maxExtras    Int?
  maxRemovable Int?
  extras       ProductExtra[]
  removables   ProductRemovable[]
  optionGroups OptionGroup[]
  // Opções de outros produtos que apontam para este (ex.: o refri dentro de um combo)
  linkedBy     OptionItem[] @relation("OptionLinkedProduct")
  items        OrderItem[]
  coupons      Coupon[]    @relation("CouponProducts")

  @@index([categoryId])
}

// ===== Grupos de opções (combos, pizza meio a meio, tamanhos) =====
// Diferente de ProductExtra (sempre aditivo e sem obrigatoriedade), um grupo
// carrega REGRA: quantas escolhas são exigidas/permitidas e como elas somam.
//
// type:        "SINGLE" (radio) | "MULTI" (checkbox)
// pricingRule: como as opções escolhidas viram preço
//   "SUM" — soma os priceDelta (padrão; adicionais, borda, tamanho)
//   "MAX" — cobra só o maior priceDelta (pizza meio a meio: vale o sabor mais caro)
//   "AVG" — média dos priceDelta (pizza meio a meio: média dos sabores)
// kind:        "ADD" (escolha que compõe/soma) | "REMOVE" (tirar ingrediente, sem custo)
model OptionGroup {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  type        String       @default("SINGLE")
  kind        String       @default("ADD")
  // minSelect > 0 torna o grupo obrigatório — é o que ProductExtra.maxExtras nunca soube fazer
  minSelect   Int          @default(0)
  maxSelect   Int? // null = sem teto
  pricingRule String       @default("SUM")
  // permite escolher a mesma opção N vezes (ex.: 2x bacon). Só faz sentido em MULTI.
  allowQuantity Boolean    @default(false)
  active      Boolean      @default(true)
  sortOrder   Int          @default(0)
  options     OptionItem[]

  @@index([productId])
}

model OptionItem {
  id              String      @id @default(cuid())
  groupId         String
  group           OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name            String
  priceDelta      Decimal     @default(0)
  // Quando preenchido, esta opção É um produto do catálogo (o refri do combo).
  // Permite que cozinha/estoque/relatórios enxerguem o item real, não só um texto.
  linkedProductId String?
  linkedProduct   Product?    @relation("OptionLinkedProduct", fields: [linkedProductId], references: [id])
  active          Boolean     @default(true)
  sortOrder       Int         @default(0)

  @@index([groupId])
  @@index([linkedProductId])
}

// ===== Loja: horários de funcionamento =====
// Singleton (id fixo "default") — este sistema atende UMA loja. Se um dia virar
// multi-loja, este é o model que vira o tenant e ganha FK em Product/Order.
model StoreSettings {
  id        String        @id @default("default")
  name      String        @default("Cabana Lanches")
  // Pausa manual: fecha a loja agora, independente do horário (fila cheia, falta de insumo)
  paused    Boolean       @default(false)
  pausedMsg String?
  // Minutos de tolerância para aceitar pedido antes de fechar
  lastOrderMinutes Int    @default(0)
  hours     OpeningHour[]
  updatedAt DateTime      @updatedAt
}

// Uma faixa de funcionamento. Vários registros no mesmo weekday = vários turnos
// (ex.: almoço 11:00-15:00 e jantar 18:00-23:00).
// opensAt/closesAt em "HH:MM" local. closesAt <= opensAt significa que vira o dia
// (ex.: 19:00 -> 02:00).
model OpeningHour {
  id        String        @id @default(cuid())
  storeId   String        @default("default")
  store     StoreSettings @relation(fields: [storeId], references: [id], onDelete: Cascade)
  weekday   Int // 0=domingo .. 6=sábado
  opensAt   String
  closesAt  String
  active    Boolean       @default(true)

  @@index([storeId])
  @@index([weekday])
}

// ===== Cupons de desconto (código digitado no checkout) =====
// type:      "PERCENT" (value = %) | "FIXED" (value = R$)
// appliesTo: "ALL" | "PRODUCTS" (lista products) | "CATEGORY" (categoryId)
model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  type        String
  value       Decimal
  active      Boolean   @default(true)
  expiresAt   DateTime?
  minSubtotal Decimal?
  maxUses     Int?
  usedCount   Int       @default(0)
  appliesTo   String    @default("ALL")
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  products    Product[] @relation("CouponProducts")
  orders      Order[]
  createdAt   DateTime  @default(now())

  @@index([categoryId])
}

// Ingrediente/adicional extra (com preço) que o cliente pode acrescentar
model ProductExtra {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal @default(0)
  sortOrder Int     @default(0)

  @@index([productId])
}

// Ingrediente que compõe o produto e que o cliente pode remover (sem custo)
model ProductRemovable {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)

  @@index([productId])
}

// ===== Pedidos =====
// status:        OrderStatus  (PENDING..CONFIRMED_BY_CUSTOMER | CANCELLED)
// paymentMethod: PaymentMethod (PIX | CREDIT_CARD | DEBIT_CARD | CASH)
model Order {
  id            String               @id @default(cuid())
  code          String               @unique
  userId        String
  user          User                 @relation(fields: [userId], references: [id])
  addressId     String
  address       Address              @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  status        String               @default("PENDING")
  paymentMethod String
  subtotal      Decimal
  deliveryFee   Decimal              @default(0)
  discount      Decimal              @default(0)
  total         Decimal
  couponId      String?
  coupon        Coupon?              @relation(fields: [couponId], references: [id])
  couponCode    String?
  notes         String?
  courierId     String?
  courier       Courier?             @relation(fields: [courierId], references: [id])
  payment       Payment?
  delivery      Delivery?
  rating        Rating?
  history       OrderStatusHistory[]
  messages      OrderMessage[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([courierId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal // já inclui extras e opções selecionadas
  notes     String?
  extrasJson  String? // JSON: [{ name, price, quantity }]
  removedJson String? // JSON: ["ingrediente", ...]
  // Escolhas dos OptionGroups (combo, sabores, tamanho). Snapshot, igual extrasJson:
  // JSON: [{ groupName, kind, pricingRule, options: [{ name, price, quantity, linkedProductId }] }]
  // Pedidos anteriores aos grupos têm null aqui — serialize trata os dois casos.
  selectionsJson String?

  @@index([orderId])
}

model OrderStatusHistory {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status            String
  changedByEmployee String? // Employee.id ou Courier.id ou "system"
  note              String?
  photoUrl          String?
  createdAt         DateTime @default(now())

  @@index([orderId])
}

// Mensagens do pedido, em 2 canais (channel): "STORE" (loja<->cliente) e
// "COURIER" (entregador<->cliente). senderType: "EMPLOYEE"|"CUSTOMER"|"COURIER".
model OrderMessage {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel    String    @default("STORE")
  senderType String
  senderId   String
  senderName String
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([orderId])
}

// status: PaymentStatus (PENDING | PAID | CONFIRMED_ON_DELIVERY | FAILED | REFUNDED)
model Payment {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method             String
  status             String    @default("PENDING")
  amount             Decimal
  pixQrCode          String?
  pixQrImageUrl      String?
  paidAt             DateTime?
  confirmedByCourier Boolean   @default(false)
}

model Delivery {
  id               String    @id @default(cuid())
  orderId          String    @unique
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierId        String
  courier          Courier   @relation(fields: [courierId], references: [id])
  pickupPhotoUrl   String?
  deliveryPhotoUrl String?
  startedAt        DateTime?
  deliveredAt      DateTime?
  lat              Float?
  lng              Float?

  @@index([courierId])
}

// ===== Entregadores =====
model Courier {
  id             String     @id @default(cuid())
  name           String
  phone          String     @unique
  password       String
  active         Boolean    @default(true)
  // Cadastro / documentos (preenchidos pelo admin no cadastro)
  photoUrl       String?
  birthDate      DateTime?
  cpf            String?
  cpfFrontUrl    String?
  cpfBackUrl     String?
  cnh            String?
  cnhFrontUrl    String?
  cnhBackUrl     String?
  currentLat     Float?
  currentLng     Float?
  lastLocationAt DateTime?
  orders         Order[]
  deliveries     Delivery[]
  createdAt      DateTime   @default(now())
}

// ===== Funcionários do restaurante (RBAC) =====
// role: EmployeeRole (ADMIN | KITCHEN | DISPATCH | ATTENDANT)
model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ===== Avaliações =====
model Rating {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  stars     Int
  comment   String?
  createdAt DateTime @default(now())
}
