# ===== App =====
NODE_ENV=development
PORT=4000
# Origens permitidas (CORS) — os 3 fronts
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,capacitor://localhost,http://localhost

# ===== Banco =====
# SQLite por enquanto. Para Postgres: postgresql://user:pass@host:5432/cabana
DATABASE_URL="file:./dev.db"

# ===== Auth (JWT) =====
JWT_ACCESS_SECRET=troque-este-segredo-de-access
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_ACCESS_TTL=900          # 15 min (segundos)
JWT_REFRESH_TTL=1209600     # 14 dias (segundos)

# ===== Uploads / StorageService =====
STORAGE_DRIVER=local        # local | r2
PUBLIC_BASE_URL=http://localhost:4000
# --- Cloudflare R2 (adapter real, opcional) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ===== PixService =====
PIX_DRIVER=mock             # mock | asaas | mercadopago | gerencianet
PIX_AUTO_CONFIRM_MS=5000    # mock confirma pagamento após N ms
PIX_API_KEY=

# ===== MapService =====
MAPS_DRIVER=mock            # mock | google | openrouteservice
MAPS_API_KEY=

# ===== PushService =====
PUSH_DRIVER=mock            # mock | fcm | webpush
FCM_SERVER_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
